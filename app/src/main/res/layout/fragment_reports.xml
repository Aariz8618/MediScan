<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:paddingHorizontal="20dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/my_reports"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Search bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_search_bar"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:tint="@color/text_hint"
                android:contentDescription="@null" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@null"
                android:hint="@string/search_hint"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:inputType="text"
                android:imeOptions="actionSearch" />

        </LinearLayout>

    </LinearLayout>

    <!-- ===== FILTER TABS ===== -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:paddingVertical="12dp"
        android:background="@color/white">

        <LinearLayout
            android:id="@+id/filter_tabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_all"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_chip"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/filter_all"
                android:textColor="@color/secondary_teal"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_lab"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_search_bar"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/filter_lab"
                android:textColor="@color/text_hint"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tab_imaging"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_search_bar"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/filter_imaging"
                android:textColor="@color/text_hint"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tab_ecg"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_search_bar"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/filter_ecg"
                android:textColor="@color/text_hint"
                android:textSize="13sp" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- ===== REPORTS RECYCLERVIEW ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_reports"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingVertical="8dp"
        android:clipToPadding="false" />

</LinearLayout>
