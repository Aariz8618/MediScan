<?xml version="1.0" encoding="utf-8"?>
<!-- SCREEN 4: Lab Report Analysis Result -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EBF2F0">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back → Processing -->
        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_btn_icon"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_gravity="center" android:src="@drawable/ic_back"/>
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Lab Report Analysis"
            android:textColor="#FFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintEnd_toStartOf="@id/aiBadge"/>

        <TextView
            android:id="@+id/aiBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ai_badge"
            android:text="AI v3.2"
            android:textColor="#FFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Meta card -->
        <LinearLayout
            android:id="@+id/metaCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_meta"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack">

            <FrameLayout android:layout_width="34dp" android:layout_height="34dp" android:background="@drawable/ic_lab_bg" android:layout_marginEnd="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🧪" android:textSize="16sp"/>
            </FrameLayout>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:id="@+id/tvReportName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Complete Blood Count" android:textColor="#FFF" android:textSize="12sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tvReportMeta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Today · 14 parameters · PDF" android:textColor="#AAFFFFFF" android:textSize="10sp" android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- TAB BAR: Summary | All Values -->
    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF"
        android:orientation="horizontal"
        android:padding="6dp"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/header">

        <TextView
            android:id="@+id/tabSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_off"
            android:gravity="center"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:text="Summary"
            android:textColor="#4A7A71"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/tabAllValues"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_on"
            android:gravity="center"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:text="All Values"
            android:textColor="#FFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- SUMMARY TAB content (empty — just a placeholder) -->
    <LinearLayout
        android:id="@+id/paneSummary"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tabBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊"
            android:textSize="48sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Summary coming soon"
            android:textColor="#1C2B2A"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="AI-generated summary will appear here after analysis"
            android:textColor="#6B8883"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- ALL VALUES TAB content -->
    <ScrollView
        android:id="@+id/paneAllValues"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/tabBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="14dp"
            android:paddingBottom="100dp">

            <!-- Overall Assessment card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tab_on" android:text=" AI " android:textColor="#FFF" android:textSize="9sp" android:textStyle="bold" android:paddingStart="6dp" android:paddingEnd="6dp" android:paddingTop="2dp" android:paddingBottom="2dp" android:layout_marginEnd="8dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Overall Assessment" android:textColor="#1C2B2A" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvAssessment" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚠ Mild" android:textColor="#E09000" android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAssessmentText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hemoglobin slightly below range. WBC elevated — possible mild infection or inflammation. Platelet count within normal limits."
                    android:textColor="#6B8883"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <!-- Parameters Table -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tbl"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <!-- Table header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tbl_hdr"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="9dp"
                    android:paddingBottom="9dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="PARAMETER" android:textColor="#CCFFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="VALUE" android:textColor="#CCFFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="NORMAL RANGE" android:textColor="#CCFFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:text="FLAG" android:textColor="#CCFFFFFF" android:textSize="9sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Row: Hemoglobin — LOW -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FFF8F8" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="10dp" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Hemoglobin" android:textColor="#1C2B2A" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="10.2 g/dL" android:textColor="#2196C4" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="12.0–17.5" android:textColor="#6B8883" android:textSize="10sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:background="@drawable/bg_flag_lo" android:gravity="center" android:text="LOW" android:textColor="#2196C4" android:textSize="8sp" android:textStyle="bold" android:paddingStart="4dp" android:paddingEnd="4dp" android:paddingTop="3dp" android:paddingBottom="3dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DCEAE7"/>

                <!-- Row: WBC Count — HIGH -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FFF8F8" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="10dp" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="WBC Count" android:textColor="#1C2B2A" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="11,800 /µL" android:textColor="#E05252" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="4,500–11,000" android:textColor="#6B8883" android:textSize="10sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:background="@drawable/bg_flag_hi" android:gravity="center" android:text="HIGH" android:textColor="#E05252" android:textSize="8sp" android:textStyle="bold" android:paddingStart="4dp" android:paddingEnd="4dp" android:paddingTop="3dp" android:paddingBottom="3dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DCEAE7"/>

                <!-- Row: Platelets — OK -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="10dp" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Platelets" android:textColor="#1C2B2A" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="245,000 /µL" android:textColor="#27A882" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="150K–400K" android:textColor="#6B8883" android:textSize="10sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:background="@drawable/bg_flag_ok" android:gravity="center" android:text="OK" android:textColor="#27A882" android:textSize="8sp" android:textStyle="bold" android:paddingStart="4dp" android:paddingEnd="4dp" android:paddingTop="3dp" android:paddingBottom="3dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DCEAE7"/>

                <!-- Row: MCV — OK -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="10dp" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="MCV" android:textColor="#1C2B2A" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="82 fL" android:textColor="#27A882" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="80–100" android:textColor="#6B8883" android:textSize="10sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:background="@drawable/bg_flag_ok" android:gravity="center" android:text="OK" android:textColor="#27A882" android:textSize="8sp" android:textStyle="bold" android:paddingStart="4dp" android:paddingEnd="4dp" android:paddingTop="3dp" android:paddingBottom="3dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DCEAE7"/>

                <!-- Row: Neutrophils — HIGH -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FFF8F8" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="10dp" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Neutrophils" android:textColor="#1C2B2A" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="78%" android:textColor="#E05252" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="40–70%" android:textColor="#6B8883" android:textSize="10sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:background="@drawable/bg_flag_hi" android:gravity="center" android:text="HIGH" android:textColor="#E05252" android:textSize="8sp" android:textStyle="bold" android:paddingStart="4dp" android:paddingEnd="4dp" android:paddingTop="3dp" android:paddingBottom="3dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DCEAE7"/>

                <!-- Row: Lymphocytes — OK -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="10dp" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Lymphocytes" android:textColor="#1C2B2A" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="22%" android:textColor="#27A882" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="20–40%" android:textColor="#6B8883" android:textSize="10sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:background="@drawable/bg_flag_ok" android:gravity="center" android:text="OK" android:textColor="#27A882" android:textSize="8sp" android:textStyle="bold" android:paddingStart="4dp" android:paddingEnd="4dp" android:paddingTop="3dp" android:paddingBottom="3dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#DCEAE7"/>

                <!-- Row: Hematocrit — LOW -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FFF8F8" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="10dp" android:paddingBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Hematocrit" android:textColor="#1C2B2A" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="31%" android:textColor="#2196C4" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="36–46%" android:textColor="#6B8883" android:textSize="10sp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:background="@drawable/bg_flag_lo" android:gravity="center" android:text="LOW" android:textColor="#2196C4" android:textSize="8sp" android:textStyle="bold" android:paddingStart="4dp" android:paddingEnd="4dp" android:paddingTop="3dp" android:paddingBottom="3dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Alert: Warning -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_alert_warn"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚠️" android:textSize="14sp" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Hemoglobin is below normal. Consider iron panel and dietary assessment. Follow up within 2 weeks." android:textColor="#7A5500" android:textSize="11sp" android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <!-- Alert: Danger -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_alert_danger"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔴" android:textSize="14sp" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Elevated WBC with high neutrophils may suggest bacterial infection. Clinical correlation recommended." android:textColor="#7A1A1A" android:textSize="11sp" android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <!-- Save to Reports button -->
            <LinearLayout
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_btn_green"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                <ImageView android:layout_width="16dp" android:layout_height="16dp" android:layout_marginEnd="8dp" android:src="@drawable/ic_save"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save to Reports"
                    android:textColor="#FFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>