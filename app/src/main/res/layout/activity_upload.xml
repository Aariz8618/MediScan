<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF7F9">

    <!-- ═══════════ HEADER — white, teal title ═══════════ -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back button -->
        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_btn_light"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="12dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                app:tint="#1A5F72"
                android:contentDescription="Back" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Report"
            android:textColor="#1A5F72"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/dm_sans_bold" />

    </LinearLayout>

    <!-- ═══════════ BODY ═══════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- ── Drop Zone — dashed teal border ── -->
            <LinearLayout
                android:id="@+id/dropZone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_upload_zone"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="36dp"
                android:paddingBottom="36dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true">

                <!-- File icon -->
                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_file_upload"
                    android:layout_marginBottom="16dp"
                    android:contentDescription="File" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drop your file here"
                    android:textColor="#1A5F72"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/dm_sans_bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PDF, JPG, PNG · Max 20 MB"
                    android:textColor="#6B8883"
                    android:textSize="12sp"
                    android:fontFamily="@font/dm_sans_regular"
                    android:layout_marginBottom="22dp" />

                <!-- Browse button -->
                <TextView
                    android:id="@+id/btnBrowse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_teal"
                    android:text="BROWSE FILES"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:fontFamily="@font/dm_sans_bold"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- ── SELECT REPORT TYPE label ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT REPORT TYPE"
                android:textColor="#4A7A71"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:fontFamily="@font/dm_sans_bold"
                android:layout_marginBottom="12dp" />

            <!-- Row 1: Lab + ECG -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">

                <LinearLayout android:id="@+id/typeLab" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="34dp" android:layout_height="34dp" android:background="@drawable/bg_report_icon_o" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🧪" android:textSize="16sp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lab Report" android:textColor="#1A5F72" android:textSize="13sp" android:textStyle="bold" android:fontFamily="@font/dm_sans_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CBC, LFT, RFT" android:textColor="#6B8883" android:textSize="10sp" android:fontFamily="@font/dm_sans_regular"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:id="@+id/typeEcg" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="34dp" android:layout_height="34dp" android:background="@drawable/bg_report_icon_b" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="💓" android:textSize="16sp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ECG Strip" android:textColor="#1A5F72" android:textSize="13sp" android:textStyle="bold" android:fontFamily="@font/dm_sans_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12-lead ECG" android:textColor="#6B8883" android:textSize="10sp" android:fontFamily="@font/dm_sans_regular"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Row 2: MRI + X-Ray -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">

                <LinearLayout android:id="@+id/typeMri" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="34dp" android:layout_height="34dp" android:background="@drawable/bg_report_icon_p" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🧠" android:textSize="16sp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MRI Scan" android:textColor="#1A5F72" android:textSize="13sp" android:textStyle="bold" android:fontFamily="@font/dm_sans_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Brain, Spine" android:textColor="#6B8883" android:textSize="10sp" android:fontFamily="@font/dm_sans_regular"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:id="@+id/typeXray" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="34dp" android:layout_height="34dp" android:background="@drawable/bg_report_icon_g" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🫁" android:textSize="16sp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="X-Ray" android:textColor="#1A5F72" android:textSize="13sp" android:textStyle="bold" android:fontFamily="@font/dm_sans_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chest, Bone" android:textColor="#6B8883" android:textSize="10sp" android:fontFamily="@font/dm_sans_regular"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Row 3: CT Scan + Retinal -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">

                <LinearLayout android:id="@+id/typeCt" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="34dp" android:layout_height="34dp" android:background="@drawable/bg_report_icon_ct" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🔬" android:textSize="16sp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CT Scan" android:textColor="#1A5F72" android:textSize="13sp" android:textStyle="bold" android:fontFamily="@font/dm_sans_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lung, Abdomen" android:textColor="#6B8883" android:textSize="10sp" android:fontFamily="@font/dm_sans_regular"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:id="@+id/typeRetinal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_type_on" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="34dp" android:layout_height="34dp" android:background="@drawable/bg_report_icon_eye" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="👁️" android:textSize="16sp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Retinal" android:textColor="#1A5F72" android:textSize="13sp" android:textStyle="bold" android:fontFamily="@font/dm_sans_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fundus image" android:textColor="#6B8883" android:textSize="10sp" android:fontFamily="@font/dm_sans_regular"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Row 4: Prescription + Other -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="24dp">

                <LinearLayout android:id="@+id/typeRx" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="34dp" android:layout_height="34dp" android:background="@drawable/bg_report_icon_rx" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="💊" android:textSize="16sp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prescription" android:textColor="#1A5F72" android:textSize="13sp" android:textStyle="bold" android:fontFamily="@font/dm_sans_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rx, Medication" android:textColor="#6B8883" android:textSize="10sp" android:fontFamily="@font/dm_sans_regular"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:id="@+id/typeOther" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="14dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="34dp" android:layout_height="34dp" android:background="@drawable/bg_report_icon_other" android:layout_marginEnd="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="📋" android:textSize="16sp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Other" android:textColor="#1A5F72" android:textSize="13sp" android:textStyle="bold" android:fontFamily="@font/dm_sans_bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Any medical doc" android:textColor="#6B8883" android:textSize="10sp" android:fontFamily="@font/dm_sans_regular"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- ── Analyze with AI button — dark navy ── -->
            <LinearLayout
                android:id="@+id/btnAnalyze"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_btn_navy"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyze with AI →"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/dm_sans_bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>