<?xml version="1.0" encoding="utf-8"?>
<!--  fragment_profile.xml
      Screenshot 1 = top section (header + health summary + group 1)
      Screenshot 2 = scrolled down (group 2 + footer)
      Bottom nav lives in activity_main.xml — NOT here.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C5E3DC"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══════════════════════════════════
             GREEN HEADER  (avatar · name · tags)
        ══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_hero_green"
            android:paddingTop="54dp"
            android:paddingBottom="28dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Avatar circle with initial -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/circle_avatar"
                    android:contentDescription="avatar" />

                <TextView
                    android:id="@+id/tv_initial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="A"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <!-- Name (populated from UserPreferences.fullName) -->
            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Name"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.01" />

            <!-- City subtitle -->
            <TextView
                android:id="@+id/tv_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="#AAD8CE"
                android:textSize="12sp" />

            <!-- Tag pills row -->
            <LinearLayout
                android:id="@+id/layout_tags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_tag1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/pill_tag"
                    android:paddingStart="11dp"
                    android:paddingEnd="11dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="🏥 MedScan"
                    android:textColor="#DDEEE9"
                    android:textSize="10.5sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_tag2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/pill_tag"
                    android:paddingStart="11dp"
                    android:paddingEnd="11dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="—"
                    android:textColor="#DDEEE9"
                    android:textSize="10.5sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_tag3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/pill_tag"
                    android:paddingStart="11dp"
                    android:paddingEnd="11dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:text="—"
                    android:textColor="#DDEEE9"
                    android:textSize="10.5sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- ══════════════════════════════════
             SCROLLABLE CONTENT AREA
        ══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="18dp"
            android:paddingBottom="110dp">

            <!-- HEALTH SUMMARY label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEALTH SUMMARY"
                android:textColor="#8AADA8"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:layout_marginBottom="10dp"
                android:layout_marginStart="2dp" />

            <!-- Stats card (Reports · Flagged · Member) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_white"
                android:padding="14dp"
                android:weightSum="3"
                android:layout_marginBottom="14dp">

                <!-- Reports -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_stat"
                    android:padding="12dp"
                    android:layout_marginEnd="5dp">
                    <TextView
                        android:id="@+id/tv_stat_reports"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#1A7F64"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REPORTS"
                        android:textColor="#8AADA8"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Flagged -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_stat"
                    android:padding="12dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp">
                    <TextView
                        android:id="@+id/tv_stat_flagged"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#E09000"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FLAGGED"
                        android:textColor="#8AADA8"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Member -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/card_stat"
                    android:padding="12dp"
                    android:layout_marginStart="5dp">
                    <TextView
                        android:id="@+id/tv_stat_member"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0mo"
                        android:textColor="#1A7F64"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEMBER"
                        android:textColor="#8AADA8"
                        android:textSize="9sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.06"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ─────────────────────────────────────
                 GROUP 1  Personal / Medical settings
            ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_white"
                android:layout_marginBottom="14dp">

                <!-- Personal Info -->
                <LinearLayout
                    android:id="@+id/row_personal_info"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/ripple_row"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/icon_bg_green">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_person_green"
                            android:contentDescription="personal info"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Personal Info"
                        android:textColor="#1C2B2A" android:textSize="13.5sp" android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="Edit" android:textColor="#8AADA8" android:textSize="12sp"/>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron" android:contentDescription="go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="62dp" android:background="#EEF4F2"/>

                <!-- Medical History -->
                <LinearLayout
                    android:id="@+id/row_medical_history"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/ripple_row"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/icon_bg_blue">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_stethoscope"
                            android:contentDescription="medical history"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Medical History"
                        android:textColor="#1C2B2A" android:textSize="13.5sp" android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_medical_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="None" android:textColor="#8AADA8" android:textSize="12sp"/>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron" android:contentDescription="go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="62dp" android:background="#EEF4F2"/>

                <!-- Current Medications -->
                <LinearLayout
                    android:id="@+id/row_medications"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/ripple_row"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/icon_bg_purple">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_pill_color"
                            android:contentDescription="medications"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Current Medications"
                        android:textColor="#1C2B2A" android:textSize="13.5sp" android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_med_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="None" android:textColor="#8AADA8" android:textSize="12sp"/>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron" android:contentDescription="go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="62dp" android:background="#EEF4F2"/>

                <!-- Allergies -->
                <LinearLayout
                    android:id="@+id/row_allergies"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/ripple_row"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/icon_bg_orange">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_allergy"
                            android:contentDescription="allergies"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Allergies"
                        android:textColor="#1C2B2A" android:textSize="13.5sp" android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_allergy_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="None" android:textColor="#8AADA8" android:textSize="12sp"/>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron" android:contentDescription="go"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ─────────────────────────────────────
                 GROUP 2  App settings + Sign Out
            ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_white"
                android:layout_marginBottom="14dp">

                <!-- Notifications -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/icon_bg_blue">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_bell_color"
                            android:contentDescription="notifications"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Notifications"
                        android:textColor="#1C2B2A" android:textSize="13.5sp" android:textStyle="bold"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_notifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:trackTint="#1A7F64"
                        app:thumbTint="#FFFFFF"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="62dp" android:background="#EEF4F2"/>

                <!-- Privacy & Security (coming soon stub) -->
                <LinearLayout
                    android:id="@+id/row_privacy"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/ripple_row"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/icon_bg_green">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_lock_green"
                            android:contentDescription="privacy"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Privacy &amp; Security"
                        android:textColor="#1C2B2A" android:textSize="13.5sp" android:textStyle="bold"/>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron" android:contentDescription="go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="62dp" android:background="#EEF4F2"/>

                <!-- Share with Doctor (coming soon stub) -->
                <LinearLayout
                    android:id="@+id/row_share"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/ripple_row"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/icon_bg_purple">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_share_purple"
                            android:contentDescription="share"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Share with Doctor"
                        android:textColor="#1C2B2A" android:textSize="13.5sp" android:textStyle="bold"/>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron" android:contentDescription="go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="62dp" android:background="#EEF4F2"/>

                <!-- Help & Support (coming soon stub) -->
                <LinearLayout
                    android:id="@+id/row_help"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/ripple_row"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/icon_bg_red">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_help_red"
                            android:contentDescription="help"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Help &amp; Support"
                        android:textColor="#1C2B2A" android:textSize="13.5sp" android:textStyle="bold"/>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron" android:contentDescription="go"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="62dp" android:background="#EEF4F2"/>

                <!-- Sign Out — RED text, triggers dialog -->
                <LinearLayout
                    android:id="@+id/row_sign_out"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:background="@drawable/ripple_row"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                        android:background="@drawable/icon_bg_red">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_logout"
                            android:contentDescription="sign out"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Sign Out"
                        android:textColor="#E05252"
                        android:textSize="13.5sp" android:textStyle="bold"/>

                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_chevron" android:contentDescription="go"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MedScan v3.2.1 · AI-Powered Medical Analysis"
                    android:textColor="#8AADA8"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="© 2026 MedScan Technologies"
                    android:textColor="#B0C8C4"
                    android:textSize="9sp" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</ScrollView>