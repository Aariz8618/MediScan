<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF7F9">

    <!-- ═══════════ HEADER — white ═══════════ -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analysis"
            android:textColor="#1A5F72"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/dm_sans_bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI-powered medical insights"
            android:textColor="#4A7A71"
            android:textSize="12sp"
            android:fontFamily="@font/dm_sans_regular"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- ═══════════ EMPTY STATE — centered ═══════════ -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="60dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Microscope emoji -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔬"
            android:textSize="72sp"
            android:layout_marginBottom="24dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No report selected"
            android:textColor="#1A5F72"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/dm_sans_bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload a report or choose from your history to get AI-powered insights and a detailed analysis."
            android:textColor="#6B8883"
            android:textSize="13sp"
            android:fontFamily="@font/dm_sans_regular"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="36dp" />

        <!-- Upload New Report button — dark navy filled -->
        <LinearLayout
            android:id="@+id/btnUpload"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_btn_navy"
            android:gravity="center"
            android:layout_marginBottom="14dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload New Report"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/dm_sans_bold" />
        </LinearLayout>

        <!-- View Existing Reports button — white outlined -->
        <LinearLayout
            android:id="@+id/btnViewReports"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_btn_outline"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View Existing Reports"
                android:textColor="#1A5F72"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/dm_sans_bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>