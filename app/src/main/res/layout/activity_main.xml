<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    ─────────────────
    Persistent shell layout.
    • fragmentContainer  → swaps between Home / Reports / Analysis / Profile fragments
    • bnav               → floating bottom nav, always visible above every fragment
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C5E3DC">

    <!-- ── Fragment host ─────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="90dp" />

    <!-- ── Floating Bottom Navigation ─────────────────────────
         Sits above all fragments. Elevation keeps it on top.
    ──────────────────────────────────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bnav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        app:cardCornerRadius="36dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- HOME -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_home"
                    android:contentDescription="Home"
                    app:tint="#1B7A5A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textSize="9.5sp"
                    android:fontFamily="@font/dm_sans_bold"
                    android:textStyle="bold"
                    android:textColor="#1B7A5A"
                    android:layout_marginTop="2dp" />

                <!-- Active dot indicator -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/bg_nav_dot"
                    android:visibility="visible" />

            </LinearLayout>

            <!-- REPORTS -->
            <LinearLayout
                android:id="@+id/navReports"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_reports"
                    android:contentDescription="Reports"
                    app:tint="#A0B5B1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reports"
                    android:textSize="9.5sp"
                    android:fontFamily="@font/dm_sans_bold"
                    android:textStyle="bold"
                    android:textColor="#A0B5B1"
                    android:layout_marginTop="2dp" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/bg_nav_dot"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ANALYSIS -->
            <LinearLayout
                android:id="@+id/navAnalysis"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_analysis"
                    android:contentDescription="Analysis"
                    app:tint="#A0B5B1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analysis"
                    android:textSize="9.5sp"
                    android:fontFamily="@font/dm_sans_bold"
                    android:textStyle="bold"
                    android:textColor="#A0B5B1"
                    android:layout_marginTop="2dp" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/bg_nav_dot"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- PROFILE -->
            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_nav_profile"
                    android:contentDescription="Profile"
                    app:tint="#A0B5B1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textSize="9.5sp"
                    android:fontFamily="@font/dm_sans_bold"
                    android:textStyle="bold"
                    android:textColor="#A0B5B1"
                    android:layout_marginTop="2dp" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/bg_nav_dot"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>