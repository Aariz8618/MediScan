<?xml version="1.0" encoding="utf-8"?>
<!-- SCREEN: Analyzing Report — progress steps -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF7F9">

    <!-- ═══════════ HEADER — white, teal title ═══════════ -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_icon_btn_light"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="12dp">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                app:tint="#1A5F72"
                android:contentDescription="Back" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analyzing Report"
                android:textColor="#1A5F72"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="@font/dm_sans_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI v3.2 · Please wait"
                android:textColor="#6B8883"
                android:textSize="12sp"
                android:fontFamily="@font/dm_sans_regular"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════ BODY ═══════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- ── Main analysis card ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="32dp">

                    <!-- Spinner circle -->
                    <ProgressBar
                        android:id="@+id/progressSpinner"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:indeterminate="true"
                        android:indeterminateTint="#1A8C6E"
                        android:layout_marginBottom="24dp" />

                    <!-- AI analyzing text -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI is analyzing your report"
                        android:textColor="#1A5F72"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/dm_sans_bold"
                        android:gravity="center"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="This usually takes 10–20 seconds"
                        android:textColor="#6B8883"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_sans_regular"
                        android:gravity="center"
                        android:layout_marginBottom="28dp" />

                    <!-- Step 1 — done -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_step_done"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="✓"
                                android:textColor="#1A8C6E"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="File uploaded &amp; validated"
                            android:textColor="#1A5F72"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/dm_sans_bold" />
                    </LinearLayout>

                    <!-- Step 2 — done -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_step_done"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="✓"
                                android:textColor="#1A8C6E"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvStep2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Document type — Lab Report"
                            android:textColor="#1A5F72"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/dm_sans_bold" />
                    </LinearLayout>

                    <!-- Step 3 — done -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_step_done"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="✓"
                                android:textColor="#1A8C6E"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OCR text extraction complete"
                            android:textColor="#1A5F72"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/dm_sans_bold" />
                    </LinearLayout>

                    <!-- Step 4 — active (AI badge) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_step_active"
                            android:layout_marginEnd="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="AI"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvStep4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Running AI medical analysis…"
                            android:textColor="#1C2B2A"
                            android:textSize="14sp"
                            android:fontFamily="@font/dm_sans_regular" />
                    </LinearLayout>

                    <!-- Step 5 — pending -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_step_pending"
                            android:layout_marginEnd="14dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Generating clinical insights"
                            android:textColor="#6B8883"
                            android:textSize="14sp"
                            android:fontFamily="@font/dm_sans_regular" />
                    </LinearLayout>

                    <!-- Step 6 — pending -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:background="@drawable/bg_step_pending"
                            android:layout_marginEnd="14dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Preparing visual report"
                            android:textColor="#6B8883"
                            android:textSize="14sp"
                            android:fontFamily="@font/dm_sans_regular" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Privacy Guaranteed card ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#1A8C6E"
                        android:layout_marginEnd="12dp"
                        android:contentDescription="Privacy" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Privacy Guaranteed"
                            android:textColor="#1A5F72"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/dm_sans_bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your data is encrypted end-to-end and never shared with third parties."
                            android:textColor="#6B8883"
                            android:textSize="11sp"
                            android:fontFamily="@font/dm_sans_regular"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginTop="3dp" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── View Results button — dark navy ── -->
            <LinearLayout
                android:id="@+id/btnViewResults"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_btn_navy"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View Results →"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/dm_sans_bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>