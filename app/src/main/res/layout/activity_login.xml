<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#C5E3DC">

    <!-- ═══════════════════════════════════════════
         HERO — solid green background
    ════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#1B7A5A">

        <!-- Logo box -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_logo_mark">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_plus_cross"
                android:contentDescription="Logo" />
        </FrameLayout>

        <!-- MedScan title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="MedScan"
            android:fontFamily="@font/playfair_display_semibold"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Your intelligent health report analyzer"
            android:fontFamily="@font/dm_sans_regular"
            android:textSize="13sp"
            android:textColor="#C0FFFFFF"
            android:gravity="center" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         FORM — mint background
    ════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:fillViewport="true"
        android:background="#C5E3DC">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="40dp">

            <!-- EMAIL FIELD — white pill, green border, envelope icon -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="20dp"
                    android:paddingRight="20dp"
                    android:background="@drawable/bg_field_email">

                    <!-- Envelope icon -->
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_email"
                        app:tint="#2A9E78"
                        android:contentDescription="Email icon" />

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginLeft="12dp"
                        android:hint="john.doe@email.com"
                        android:textColorHint="#9BBFB8"
                        android:textColor="#2C4A45"
                        android:textSize="14sp"
                        android:fontFamily="@font/dm_sans_regular"
                        android:inputType="textEmailAddress"
                        android:background="@null"
                        android:maxLines="1"
                        android:imeOptions="actionNext" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- PASSWORD FIELD — white pill, grey border, lock icon + eye icon -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="20dp"
                    android:paddingRight="16dp"
                    android:background="@drawable/bg_field_normal">

                    <!-- Lock icon -->
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#8EAAA5"
                        android:contentDescription="Password icon" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginLeft="12dp"
                        android:hint="••••••••"
                        android:textColorHint="#BBCCCA"
                        android:textColor="#2C4A45"
                        android:textSize="16sp"
                        android:fontFamily="@font/dm_sans_regular"
                        android:inputType="textPassword"
                        android:background="@null"
                        android:maxLines="1"
                        android:imeOptions="actionDone" />

                    <!-- Eye icon -->
                    <ImageView
                        android:id="@+id/ivTogglePassword"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_eye"
                        app:tint="#AAAAAA"
                        android:contentDescription="Toggle password"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- FORGOT PASSWORD — right aligned -->
            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:layout_marginBottom="20dp"
                android:text="Forgot Password?"
                android:textColor="#2A9E78"
                android:textSize="13sp"
                android:fontFamily="@font/dm_sans_semibold"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <!-- LOGIN BUTTON — dark green pill, text fully centered -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginBottom="20dp"
                android:text="Login"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/dm_sans_bold"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:background="@drawable/bg_btn_login"
                android:stateListAnimator="@null"
                android:elevation="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <!-- DIVIDER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#B0D0C8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="14dp"
                    android:paddingRight="14dp"
                    android:text="or continue with"
                    android:textColor="#7AA09A"
                    android:textSize="12sp"
                    android:fontFamily="@font/dm_sans_regular" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#B0D0C8" />
            </LinearLayout>

            <!-- GOOGLE BUTTON — white pill, G icon + text centered -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:cardCornerRadius="30dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="26dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_field_normal">

                    <!-- Google G logo — NO tint, keeps full color -->
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_google"
                        android:contentDescription="Google" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="10dp"
                        android:text="Sign in with Google"
                        android:textColor="#2C4A45"
                        android:textSize="14sp"
                        android:fontFamily="@font/dm_sans_semibold"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SIGN UP ROW — centered -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don&#8217;t have an account?  "
                    android:textColor="#7AA09A"
                    android:textSize="13sp"
                    android:fontFamily="@font/dm_sans_regular" />

                <TextView
                    android:id="@+id/tvSignUp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Up"
                    android:textColor="#2A9E78"
                    android:textSize="13sp"
                    android:fontFamily="@font/dm_sans_bold"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>