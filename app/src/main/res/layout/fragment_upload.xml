<?xml version="1.0" encoding="utf-8"?>
<!-- SCREEN 2: Upload Report -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EBF2F0">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back → Analysis -->
        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_btn_icon"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Upload Report"
            android:textColor="#FFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Select report type and upload your file"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BODY -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="100dp">

            <!-- Drop zone -->
            <LinearLayout
                android:id="@+id/dropZone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_upload_zone"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="32dp"
                android:paddingBottom="32dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_upload_icon"
                    android:layout_marginBottom="14dp">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_file" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drop your file here"
                    android:textColor="#1C2B2A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Supports PDF, JPG, PNG · Max 20MB"
                    android:textColor="#6B8883"
                    android:textSize="12sp"
                    android:layout_marginBottom="20dp" />

                <TextView
                    android:id="@+id/btnBrowse"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_green"
                    android:text="Browse Files"
                    android:textColor="#FFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Select Report Type label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT REPORT TYPE"
                android:textColor="#6B8883"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <!-- Type cards grid -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                <LinearLayout android:id="@+id/typeLab" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/bg_type_on" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/ic_lab_bg" android:layout_marginEnd="8dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🧪" android:textSize="15sp"/></FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lab Report" android:textColor="#1C2B2A" android:textSize="12sp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CBC, LFT, RFT" android:textColor="#6B8883" android:textSize="10sp"/></LinearLayout>
                </LinearLayout>
                <LinearLayout android:id="@+id/typeEcg" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/ic_ecg_bg" android:layout_marginEnd="8dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="💓" android:textSize="15sp"/></FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ECG Strip" android:textColor="#1C2B2A" android:textSize="12sp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12-lead ECG" android:textColor="#6B8883" android:textSize="10sp"/></LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                <LinearLayout android:id="@+id/typeMri" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/ic_mri_bg" android:layout_marginEnd="8dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🧠" android:textSize="15sp"/></FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MRI Scan" android:textColor="#1C2B2A" android:textSize="12sp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Brain, Spine" android:textColor="#6B8883" android:textSize="10sp"/></LinearLayout>
                </LinearLayout>
                <LinearLayout android:id="@+id/typeXray" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/ic_xray_bg" android:layout_marginEnd="8dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🫁" android:textSize="15sp"/></FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="X-Ray" android:textColor="#1C2B2A" android:textSize="12sp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chest, Bone" android:textColor="#6B8883" android:textSize="10sp"/></LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="20dp">
                <LinearLayout android:id="@+id/typeCt" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="8dp" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/ic_ct_bg" android:layout_marginEnd="8dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🔬" android:textSize="15sp"/></FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CT Scan" android:textColor="#1C2B2A" android:textSize="12sp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lung, Abdomen" android:textColor="#6B8883" android:textSize="10sp"/></LinearLayout>
                </LinearLayout>
                <LinearLayout android:id="@+id/typeRetinal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:background="@drawable/bg_type_off" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:clickable="true" android:focusable="true">
                    <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/ic_eye_bg" android:layout_marginEnd="8dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="👁️" android:textSize="15sp"/></FrameLayout>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Retinal" android:textColor="#1C2B2A" android:textSize="12sp" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fundus image" android:textColor="#6B8883" android:textSize="10sp"/></LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Analyze button -->
            <LinearLayout
                android:id="@+id/btnAnalyze"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_btn_green"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analyze with AI →"
                    android:textColor="#FFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>