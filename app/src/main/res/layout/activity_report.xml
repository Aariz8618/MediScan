<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF7F9">

    <!-- HEADER — white card style like image 1 -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Reports"
                    android:textColor="#1A5F72"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/dm_sans_bold" />

                <TextView
                    android:id="@+id/tvSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 reports · 0 need review"
                    android:textColor="#4A7A71"
                    android:textSize="12sp"
                    android:fontFamily="@font/dm_sans_regular"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Menu button -->
            <FrameLayout
                android:id="@+id/btnMenu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_btn_light"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_menu"
                    app:tint="#1A5F72"
                    android:contentDescription="Menu" />
            </FrameLayout>

        </LinearLayout>

        <!-- Search bar -->
        <LinearLayout
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search_light"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_search"
                app:tint="#9BBFB8"
                android:contentDescription="Search" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:text="Search reports..."
                android:textColor="#9BBFB8"
                android:textSize="13sp"
                android:fontFamily="@font/dm_sans_regular" />
        </LinearLayout>

    </LinearLayout>

    <!-- FILTER TABS — white bg, teal underline for active -->
    <HorizontalScrollView
        android:id="@+id/tabsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:id="@+id/tabsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginEnd="8dp">
                <TextView
                    android:id="@+id/tabAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="10dp"
                    android:text="All"
                    android:textColor="#1A8C6E"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/dm_sans_bold"
                    android:clickable="true"
                    android:focusable="true" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#1A8C6E" />
            </LinearLayout>

            <TextView
                android:id="@+id/tabLab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp"
                android:text="Lab"
                android:textColor="#6B8883"
                android:textSize="13sp"
                android:fontFamily="@font/dm_sans_regular"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tabImg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp"
                android:text="Imaging"
                android:textColor="#6B8883"
                android:textSize="13sp"
                android:fontFamily="@font/dm_sans_regular"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tabEcg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp"
                android:text="ECG"
                android:textColor="#6B8883"
                android:textSize="13sp"
                android:fontFamily="@font/dm_sans_regular"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- REPORT LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReports"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="90dp"
        android:scrollbars="none"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabsScroll" />

    <!-- EMPTY STATE -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabsScroll">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋"
            android:textSize="52sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="No reports yet"
            android:textColor="#1C2B2A"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/dm_sans_bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="Upload a report to get AI insights"
            android:textColor="#6B8883"
            android:textSize="13sp"
            android:fontFamily="@font/dm_sans_regular" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>