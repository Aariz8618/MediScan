<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_color"
    android:gravity="center">

    <!-- ===== CIRCULAR PROGRESS ===== -->
    <ProgressBar
        android:id="@+id/progress_circular"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/accent_teal"
        style="?attr/progressBarStyleLarge" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/processing_title"
        android:textColor="@color/primary_dark_blue"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- ===== ANALYSIS STEPS ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="32dp">

        <!-- Step 1: Upload complete -->
        <LinearLayout
            android:id="@+id/step_upload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="10dp">

            <ImageView
                android:id="@+id/ic_step_upload"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check"
                android:tint="@color/bright_accent"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/step_upload"
                android:textColor="@color/text_dark"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Step 2: OCR extraction -->
        <LinearLayout
            android:id="@+id/step_ocr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="10dp">

            <ProgressBar
                android:id="@+id/progress_ocr"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/accent_teal"
                style="?attr/progressBarStyleSmall" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/step_ocr"
                android:textColor="@color/accent_teal"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Step 3: Medical data detection -->
        <LinearLayout
            android:id="@+id/step_detect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="10dp"
            android:alpha="0.5">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check"
                android:tint="@color/divider_color"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/step_detect"
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Step 4: AI reasoning -->
        <LinearLayout
            android:id="@+id/step_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="10dp"
            android:alpha="0.5">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check"
                android:tint="@color/divider_color"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/step_reason"
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Step 5: Generating explanation -->
        <LinearLayout
            android:id="@+id/step_explain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="10dp"
            android:alpha="0.5">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check"
                android:tint="@color/divider_color"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/step_explain"
                android:textColor="@color/text_hint"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
