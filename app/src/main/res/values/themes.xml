<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme — used by AndroidManifest.xml -->
    <style name="Theme.MediScan" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Status bar colour -->
        <item name="android:statusBarColor">#1B7A5A</item>
        <!-- Light status bar icons = false (white icons on dark green) -->
        <item name="android:windowLightStatusBar">false</item>
        <!-- No action bar -->
        <item name="android:windowNoTitle">true</item>
        <!-- App background -->
        <item name="android:windowBackground">#C5E3DC</item>
        <!-- Primary colour for Material components -->
        <item name="colorPrimary">#1B7A5A</item>
        <item name="colorPrimaryVariant">#145F4B</item>
        <item name="colorOnPrimary">#FFFFFF</item>
    </style>

    <!-- Splash screen theme — applied only to SplashActivity -->
    <style name="Theme.MediScan.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Dark charcoal instantly on cold start — zero white flash -->
        <item name="android:windowBackground">#1A1E24</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">#1A1E24</item>
        <item name="android:navigationBarColor">#1A1E24</item>
        <!-- false = white icons on dark background -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="colorPrimary">#00D4C8</item>
    </style>

</resources>