<?xml version="1.0" encoding="utf-8"?>
<!--
    alert_success.xml
    res/drawable/alert_success.xml
    Success / OK alert banner (.alert-ok)
    Background: #F0FAF4  |  Border: #C0E8D0 (green)  |  Radius: 10dp
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#F0FAF4" />
    <stroke
        android:width="2dp"
        android:color="#C0E8D0" />
    <corners android:radius="10dp" />
</shape>