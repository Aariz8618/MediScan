<?xml version="1.0" encoding="utf-8"?>
<!--
    alert_warning.xml
    res/drawable/alert_warning.xml
    Warning alert banner (.alert-w)
    Background: #FDF6E8  |  Border: #F0D090 (amber)  |  Radius: 10dp
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FDF6E8" />
    <stroke
        android:width="2dp"
        android:color="#F0D090" />
    <corners android:radius="10dp" />
</shape>